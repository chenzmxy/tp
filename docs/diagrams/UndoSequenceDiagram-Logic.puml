@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant "FindOrderCommandParser" as Parser
participant "ArgumentTokenizer" as Tokenizer
participant "OrderContainsKeywordsPredicate" as Predicate
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box
[-> FindOrderCommandParser : parse("i/pizza")
activate FindOrderCommandParser

Parser ->> Tokenizer: tokenize(args, PREFIX_ITEM, PREFIX_ADDRESS, PREFIX_CUSTOMER, PREFIX_STATUS)
activate Tokenizer
Tokenizer -->> Parser: ArgumentMultimap
deactivate Tokenizer

Parser ->> Parser: extract values from prefixes\n(Item: "pizza", others: empty)
Parser ->> Parser: validate non-empty values
Parser ->> Parser: count criteria = 1 (at least one required)
Parser ->> Parser: build searchMap:\n{ITEM → "pizza"}

Parser ->> Predicate: new OrderContainsKeywordsPredicate(searchMap)
activate Predicate
Predicate -->> Parser: predicate instance created
deactivate Predicate

Parser -->> CB: FindOrderCommand(predicate)
deactivate Parser
@enduml
